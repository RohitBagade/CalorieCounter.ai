# OpenAI — required. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model (default gpt-4o-mini — cheap + fast + JSON mode)
OPENAI_MODEL=gpt-4o-mini

# Server port
PORT=8080

# Allowed frontend origin(s), comma-separated. In prod set your deployed frontend URL.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
